# Bot token (Discord Developer Portal -> Bot -> Reset Token)
DISCORD_TOKEN=

# ID of the existing "Muted" role (enable Developer Mode in Discord,
# right-click the role -> Copy ID)
MUTED_ROLE_ID=

# Detection window in milliseconds (default 5000 = 5s)
WINDOW_MS=5000

# Minimum number of distinct channels to count as spam (default 2)
MIN_CHANNELS=2

# Max Hamming distance between pHashes to treat two images as equal (0-64).
# Higher = more tolerant. Default 6.
IMAGE_HASH_THRESHOLD=6
