# Token del bot (Discord Developer Portal -> Bot -> Reset Token)
DISCORD_TOKEN=

# ID del rol "Silenciado" ya existente (activá Modo Desarrollador en Discord,
# clic derecho sobre el rol -> Copiar ID)
MUTED_ROLE_ID=

# Ventana de detección en milisegundos (por defecto 5000 = 5 s)
WINDOW_MS=5000

# Cantidad mínima de canales distintos para considerar spam (por defecto 2)
MIN_CHANNELS=2

# Distancia de Hamming máxima entre pHashes para considerar dos imágenes
# iguales (0-64). Más alto = más tolerante. Por defecto 6.
IMAGE_HASH_THRESHOLD=6
